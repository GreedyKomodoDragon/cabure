{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string" }
      }
    },
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "leaderElection": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "operator": {
      "type": "object",
      "properties": {
        "watchNamespace": { "type": "string" },
        "concurrentReconciles": { "type": "integer", "minimum": 1 },
        "minimumRequeueInterval": { "type": "string" },
        "allowClusterScopedResources": { "type": "boolean" },
        "allowedRepositoryPrefixes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fieldManager": { "type": "string" }
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string" },
            "storageClass": { "type": "string" },
            "accessModes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
